{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "${workspaceFolder}": "${workspaceFolder}"
            }
        },
        {
            "name": "Pest: current file",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/vendor/bin/pest",
            "args": ["--filter=${fileBasenameNoExtension}"],
            "cwd": "${workspaceFolder}",
            "port": 9003,
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes"
            ]
        },
        {
            "name": "Pest: all tests",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/vendor/bin/pest",
            "cwd": "${workspaceFolder}",
            "port": 9003,
            "runtimeArgs": [
                "-dxdebug.mode=debug",
                "-dxdebug.start_with_request=yes"
            ]
        }
    ]
}
